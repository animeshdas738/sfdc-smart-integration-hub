<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Integration Log</label>
    <pluralLabel>Integration Logs</pluralLabel>
    <nameField>
        <type>AutoNumber</type>
        <label>Integration Log Number</label>
        <displayFormat>IL-{000000}</displayFormat>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>false</enableActivities>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
    <fields>
        <fullName>Integration_Name__c</fullName>
        <label>Integration Name</label>
        <type>Text</type>
        <length>255</length>
    </fields>
    <fields>
        <fullName>Payload_Id__c</fullName>
        <label>Payload Id</label>
        <type>Text</type>
        <length>255</length>
        <externalId>true</externalId>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <label>Status</label>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Queued</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>InProgress</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Success</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>RetryScheduled</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>DeadLetter</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Failed</fullName>
                    <default>false</default>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Attempts__c</fullName>
        <label>Attempts</label>
        <type>Number</type>
        <precision>3</precision>
        <scale>0</scale>
    </fields>
    <fields>
        <fullName>Next_Attempt_At__c</fullName>
        <label>Next Attempt At</label>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>Error_Code__c</fullName>
        <label>Error Code</label>
        <type>Text</type>
        <length>100</length>
    </fields>
    <fields>
        <fullName>Error_Message__c</fullName>
        <label>Error Message</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>Payload__c</fullName>
        <label>Payload</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>10</visibleLines>
    </fields>
    <fields>
        <fullName>Related_Record_Id__c</fullName>
        <label>Related Record Id</label>
        <type>Text</type>
        <length>255</length>
    </fields>
    <fields>
        <fullName>Source__c</fullName>
        <label>Source</label>
        <type>Text</type>
        <length>100</length>
    </fields>
    <fields>
        <fullName>CreatedByIntegration__c</fullName>
        <label>Created By Integration</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
    </fields>
</CustomObject>
